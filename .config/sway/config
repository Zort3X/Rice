# SwayFX Config - Surgical Gruvbox
# High-performance setup with rounded corners and effects.

set $mod Mod4
set $term foot
set $menu rofi -show drun -theme $HOME/.config/rofi/style.rasi

### SwayFX Effects
corner_radius 12
shadows on
shadow_blur_radius 20
shadow_color #00000044

# Blur settings
blur on
blur_xray off
blur_passes 2
blur_radius 5

# Window opacity
default_dim_inactive 0.06

### Autostart
exec dbus-update-activation-environment --systemd WAYLAND_DISPLAY XDG_CURRENT_DESKTOP=sway
exec waybar & wl-paste --type text --watch cliphist store & wl-paste --type image --watch cliphist store & autotiling
exec swaybg -i ~/.config/background/bg.png -m fill || swaybg -c '#282828'
# Direct Swayidle logic (Calibrated for Laptop - will be symlinked)
exec swayidle -w \
    timeout 150 'brightnessctl -s set 10%' resume 'brightnessctl -r' \
    timeout 300 "swaylock" \
    timeout 600 'swaymsg "output * power off"' resume 'swaymsg "output * power on"' \
    timeout 1200 'systemctl suspend' \
    timeout 2400 'systemctl hibernate' \
    before-sleep "swaylock"
exec swaymsg "seat seat0 xcursor_theme Bibata-Modern-Classic 24"

### Input
seat seat0 xcursor_theme Bibata-Modern-Classic 24
seat seat0 hide_cursor 0
input "type:keyboard" {
    xkb_layout "us,bg"
    xkb_variant ",phonetic"
    xkb_options "grp:alt_shift_toggle"
}

input "type:touchpad" {
    natural_scroll disabled
}

### Appearance
gaps inner 8
gaps outer 16
default_border pixel 2
default_floating_border pixel 2
smart_borders off
smart_gaps off

# Gruvbox Colors (Surgical Palette)
# class                 border  backgr. text    indicator child_border
client.focused          #b8bb26 #282828 #ebdbb2 #b8bb26   #b8bb26
client.focused_inactive #373533 #282828 #ebdbb2 #373533   #373533
client.unfocused        #373533 #282828 #ebdbb2 #373533   #373533
client.urgent           #fb4934 #282828 #ebdbb2 #fb4934   #fb4934

### Keybindings
bindsym $mod+Return exec $term
bindsym $mod+d exec $menu
bindsym $mod+x exec $HOME/.config/rofi/powermenu.sh
bindsym $mod+Shift+d exec rofi -show run -theme $HOME/.config/rofi/style.rasi
bindsym $mod+Tab exec rofi -show window -theme $HOME/.config/rofi/style.rasi
bindsym $mod+Shift+q kill
bindsym $mod+Shift+e exec swaynag -t warning -m 'Exit Sway?' -b 'Fuck this shit.' 'swaymsg exit'
bindsym $mod+r layout toggle split
bindsym $mod+f fullscreen toggle

# Window Focus
bindsym $mod+left focus left
bindsym $mod+right focus right
bindsym $mod+up focus up
bindsym $mod+down focus down

# Move Window
bindsym $mod+Shift+left move left
bindsym $mod+Shift+right move right
bindsym $mod+Shift+up move up
bindsym $mod+Shift+down move down

# Resize Window (Translated from Hyprland Alt+Ctrl)
bindsym Control+Mod1+left resize shrink width 25 px
bindsym Control+Mod1+right resize grow width 25 px
bindsym Control+Mod1+up resize shrink height 25 px
bindsym Control+Mod1+down resize grow height 25 px

# Workspaces
bindsym $mod+1 workspace number 1
bindsym $mod+2 workspace number 2
bindsym $mod+3 workspace number 3
bindsym $mod+4 workspace number 4
bindsym $mod+5 workspace number 5
bindsym $mod+6 workspace number 6
bindsym $mod+7 workspace number 7
bindsym $mod+8 workspace number 8
bindsym $mod+9 workspace number 9
bindsym $mod+0 workspace number 10

# Move to Workspace
bindsym $mod+Shift+1 move container to workspace number 1
bindsym $mod+Shift+2 move container to workspace number 2
bindsym $mod+Shift+3 move container to workspace number 3
bindsym $mod+Shift+4 move container to workspace number 4
bindsym $mod+Shift+5 move container to workspace number 5
bindsym $mod+Shift+6 move container to workspace number 6
bindsym $mod+Shift+7 move container to workspace number 7
bindsym $mod+Shift+8 move container to workspace number 8
bindsym $mod+Shift+9 move container to workspace number 9
bindsym $mod+Shift+0 move container to workspace number 10

# Screenshot
bindsym $mod+Shift+s exec grim -g "$(slurp)" - | wl-copy
bindsym $mod+Print exec grim - | wl-copy

# Audio
bindsym --locked XF86AudioRaiseVolume exec wpctl set-volume -l 1.0 @DEFAULT_AUDIO_SINK@ 5%+
bindsym --locked XF86AudioLowerVolume exec wpctl set-volume @DEFAULT_AUDIO_SINK@ 5%-
bindsym --locked XF86AudioMute exec wpctl set-mute @DEFAULT_AUDIO_SINK@ toggle

# Mouse bindings
floating_modifier $mod normal

include /etc/sway/config.d/*
